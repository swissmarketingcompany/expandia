# ElevenLabs solar demo audio generation
# Copy these names into .env.local and replace the placeholder values.
ELEVENLABS_API_KEY=your_restricted_api_key
ELEVENLABS_AGENT_VOICE_ID=your_agent_voice_id
ELEVENLABS_PROSPECT_VOICE_ID=your_prospect_voice_id

# Optional. Text to Dialogue defaults to Eleven v3.
ELEVENLABS_MODEL_ID=eleven_v3
